# .streamlit/secrets.toml.example
# ================================
# Copy this file to .streamlit/secrets.toml and fill in your real credentials.
# IMPORTANT: secrets.toml is listed in .gitignore — never commit the real file.

# Anthropic Claude API key
# Get yours at: https://console.anthropic.com
anthropic_api_key = "sk-ant-api03-YOUR_KEY_HERE"

# MongoDB Atlas connection string
# Create a free cluster at: https://www.mongodb.com/cloud/atlas
[mongodb]
uri = "mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lem_stratiq?retryWrites=true&w=majority"

# Google OAuth credentials
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
[auth]
client_id     = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"

# LinkedIn OAuth credentials
# Create at: https://www.linkedin.com/developers/apps
[linkedin]
client_id     = "YOUR_LINKEDIN_CLIENT_ID"
client_secret = "YOUR_LINKEDIN_CLIENT_SECRET"

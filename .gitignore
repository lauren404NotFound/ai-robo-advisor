# ================================================================
# LEM StratIQ — AI Robo-Advisor  |  .gitignore
# ================================================================

# ── Secrets — NEVER commit ──────────────────────────────────────
.streamlit/secrets.toml
ai_robo_advisor/.streamlit/secrets.toml
**/secrets.toml

# ── Python cache ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── ML model artefacts (regenerated by running train_model.py) ──
# These are binary blobs that bloat the repo.  Regenerate with:
#   cd ai_robo_advisor && python train_model.py
ai_robo_advisor/model.pkl
ai_robo_advisor/scaler.pkl
ai_robo_advisor/label_encoder.pkl
ai_robo_advisor/feature_names.pkl

# ── Robo_P* saved settings (binary, re-created by MaxSR training) ─
Robo_P*/MaxSR/saved_settings/saved_settings.pkl
Robo_P*/OOS_results/result.pickle

# ── Generated chart / visualisation outputs ─────────────────────
# PNGs in Robo_P*/portfolios/hyperparameters/ and special_portfolios/
# are output plots — not source data.
Robo_P*/portfolios/hyperparameters/*.png
Robo_P*/portfolios/special_portfolios/**/*.png
Robo_P*/portfolios/special_portfolios/**/*.csv

# Robo1/Robo2/Robo3 are legacy duplicate output directories
Robo1/
Robo2/
Robo3/

# ── Database files ───────────────────────────────────────────────
*.db
*.sqlite
ai_robo_advisor/robo_advisor.db

# ── iCloud placeholder files ─────────────────────────────────────
*.icloud

# ── Stale fix/patch scripts (one-off migration scripts) ──────────
fix_*.py
patch_*.py
migrate_*.py

# ── Monolith backup (superseded by modular architecture) ─────────
ai_robo_advisor/app_monolith_backup.py

# ── Coverage & test output ───────────────────────────────────────
.coverage
coverage.xml
test-results.xml
htmlcov/

# ── Build / distribution ────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── macOS junk ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDE ──────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────
*.log
streamlit.log

# ── Jupyter ──────────────────────────────────────────────────────
.ipynb_checkpoints/

# NOTE: Robo_P*/portfolios/shdiq_wgts_maxsr_*.csv  ← KEPT in git
#       These are the model weight CSVs read at runtime by portfolio_engine.py
# NOTE: Robo_P*/MaxSR/price_data/*.csv             ← KEPT in git
#       These are input price series required for MaxSR training
